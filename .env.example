# Core service settings
PORT=8080
CONFIG_PATH=config.yaml

# LLM settings
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/chat

# MLflow observability via FastAPI sidecar
MLFLOW_ENABLED=true
MLFLOW_FASTAPI_URL=http://127.0.0.1:8001
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=existing_project_dev
